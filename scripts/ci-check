#!/usr/bin/env bash
# CI verification: run tests, clippy (no warnings), and build with/without
# the extended-api feature.
set -euo pipefail

cd "$(dirname "$0")/.."

run() {
    echo
    echo "==> $*"
    "$@"
}

# Formatting must be clean.
run cargo fmt --all -- --check

# Tests across the workspace. Prefer nextest (per-test timeouts) when
# available; fall back to `cargo test` otherwise.
if cargo nextest --version >/dev/null 2>&1; then
    run cargo nextest run --workspace --no-fail-fast
else
    echo "note: cargo-nextest not found, falling back to 'cargo test'"
    run cargo test --workspace --no-fail-fast
fi

# Clippy: fail on any warning. Run both with and without extended-api so
# the gated `extensions/` modules are also linted.
run cargo clippy --workspace --all-targets -- -D warnings
run cargo clippy -p libxev -p libxev-sys --all-targets \
    --features libxev/extended-api -- -D warnings

# Build matrix: without extended-api (whole workspace) and with extended-api
# (the crates that expose the feature).
run cargo build --workspace
run cargo build -p libxev -p libxev-sys --features libxev/extended-api

echo
echo "All CI checks passed."
